{
  "name": "materialui-react-time-picker",
  "version": "1.0.2",
  "description": "Material Design 3 style React time picker component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "demo": "node ./node_modules/vite/bin/vite.js --config vite.demo.config.js",
    "build:demo": "node ./node_modules/vite/bin/vite.js build --config vite.demo.config.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "react-time-picker",
    "time-picker",
    "timepicker",
    "material-ui",
    "mui",
    "material-design",
    "md3",
    "clock-picker",
    "component"
  ],
  "author": "thomas gupta <thomasgupta9759@gmail.com>",
  "license": "ISC",
  "homepage": "https://tamasgupta.github.io/Npm-package-materialui-react-time-picker/",
  "repository": {
    "type": "git",
    "url": "https://github.com/tamasgupta/Npm-package-materialui-react-time-picker.git"
  },
  "bugs": {
    "url": "https://github.com/tamasgupta/Npm-package-materialui-react-time-picker/issues"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.3"
  }
}
