{
  "name": "materialui-react-time-picker",
  "version": "1.0.2",
  "description": "Material Design 3 style React time picker component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "demo": "vite --config vite.demo.config.js",
    "build:demo": "vite build --config vite.demo.config.js",
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-time-picker",
    "time picker",
    "materialui-time-picker",
    "updated",
    "most downloaded",
    "ui",
    "design"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.3"
  }
}
